# Configurações da API
HOST=0.0.0.0
PORT=8000
DEBUG=True

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# URLs e Autenticação Evolution API
EVOLUTION_API_URL=http://your-evolution-api-url:8080
EVOLUTION_API_KEY=your-evolution-api-key-here

# Redis
# Defina uma senha forte para o Redis (exemplo: openssl rand -base64 32)
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Webhook
# Gere um secret usando: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here

# Configurações da Sessão
SESSION_TIMEOUT=3600
CONTEXT_WINDOW_SIZE=10

# Rate Limiting
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=3600