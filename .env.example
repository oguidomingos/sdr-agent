# =============================================================================
# SDR AGENT MULTI-CLIENT SAAS CONFIGURATION
# =============================================================================

# Application Settings
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development

# Security
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION_HOURS=24

# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_DB=sdr_agent
POSTGRES_USER=sdr_user
POSTGRES_PASSWORD=sdr_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full database URL for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://sdr_user:sdr_password@postgres:5432/sdr_agent

# Redis Configuration
# =============================================================================
# Generate strong password: openssl rand -base64 32
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Session Management
# =============================================================================
SESSION_TIMEOUT=3600
CONTEXT_WINDOW_SIZE=20
MAX_HISTORY_MESSAGES=100

# AI Configuration (Default/Fallback)
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
DEFAULT_AI_TEMPERATURE=0.7
DEFAULT_AI_MAX_TOKENS=1000

# WhatsApp Integration (Default/Fallback)
# =============================================================================
EVOLUTION_API_URL=http://your-evolution-api-url:8080
EVOLUTION_API_KEY=your-evolution-api-key-here
DEFAULT_EVOLUTION_INSTANCE=default

# Rate Limiting
# =============================================================================
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=3600
RATE_LIMIT_ENABLED=true

# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/sdr-agent.log
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=30

# CORS Settings
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true

# File Upload Settings
# =============================================================================
MAX_FILE_SIZE=10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Webhook Configuration
# =============================================================================
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5

# Multi-Tenant Features
# =============================================================================
DEFAULT_CLIENT_NAME=Demo Client
DEFAULT_CLIENT_DOMAIN=demo.sdr-agent.com
ENABLE_CLIENT_SIGNUP=false
REQUIRE_CLIENT_APPROVAL=true

# Performance Settings
# =============================================================================
MAX_CONCURRENT_REQUESTS=100
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Monitoring & Analytics
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
ANALYTICS_RETENTION_DAYS=90

# Email Configuration (Optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SDR Agent
SMTP_FROM_EMAIL=noreply@sdr-agent.com

# External Integrations (Optional)
# =============================================================================
CALENDAR_PROVIDER=google
GOOGLE_CALENDAR_CREDENTIALS_PATH=/app/credentials/google-calendar.json
CRM_INTEGRATION_ENABLED=false
CRM_WEBHOOK_URL=https://your-crm.com/webhook

# Development/Testing
# =============================================================================
MOCK_WHATSAPP_RESPONSES=false
ENABLE_TEST_ENDPOINTS=false
SEED_DATABASE=true